{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jayson-Furr/VerityFoundry/schemas/release-review-bundle-manifest.schema.json",
  "title": "VerityFoundry release-review bundle manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bundleId",
    "mode",
    "createdAt",
    "createdBy",
    "source",
    "retention",
    "artifacts",
    "validation",
    "notes"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": [
        "1.0"
      ]
    },
    "bundleId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]+$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "planned-dry-run",
        "generated"
      ]
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "createdBy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "version"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "const": "verityfoundry"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "ref",
        "commit",
        "releaseTag"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 1
        },
        "releaseTag": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context",
        "suggestedDays"
      ],
      "properties": {
        "context": {
          "type": "string",
          "enum": [
            "pull-request",
            "main",
            "release-tag"
          ]
        },
        "suggestedDays": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "localOnly",
        "externalAiApisAllowed",
        "dryRunCommand",
        "veritySpecAuthorityBoundary",
        "humanReviewRequired"
      ],
      "properties": {
        "localOnly": {
          "type": "boolean",
          "const": true
        },
        "externalAiApisAllowed": {
          "type": "boolean",
          "const": false
        },
        "dryRunCommand": {
          "type": "string",
          "minLength": 1
        },
        "veritySpecAuthorityBoundary": {
          "type": "string",
          "minLength": 1
        },
        "humanReviewRequired": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "path",
        "artifactType",
        "required",
        "producerCommand",
        "checksum"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "artifactType": {
          "type": "string",
          "enum": [
            "report",
            "snapshot",
            "fixture",
            "manifest",
            "metadata"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "producerCommand": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        }
      }
    },
    "checksum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "state",
        "digest"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "sha256"
        },
        "state": {
          "type": "string",
          "enum": [
            "planned",
            "computed"
          ]
        },
        "digest": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
