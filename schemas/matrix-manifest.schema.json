{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jayson-Furr/VerityFoundry/schemas/matrix-manifest.schema.json",
  "title": "VerityFoundry matrix manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "domain",
    "rows"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "domain",
          "input",
          "interviewMode",
          "target",
          "output"
        ],
        "properties": {
          "domain": {
            "type": "string"
          },
          "input": {
            "type": "string"
          },
          "interviewMode": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "output": {
            "type": "string"
          },
          "promptId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9.-]*\\.v[0-9]+$"
          }
        }
      }
    }
  }
}
