{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jason-Furr/verity-foundry/schemas/golden-output.schema.json",
  "title": "VerityFoundry golden output manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "domain",
    "promptRef",
    "exampleRef",
    "interviewMode",
    "targetReadiness",
    "outputPath",
    "requiredSections",
    "notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "promptRef": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*\\.v[0-9]+$"
    },
    "exampleRef": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*$"
    },
    "interviewMode": {
      "type": "string",
      "minLength": 1
    },
    "targetReadiness": {
      "type": "string",
      "minLength": 1
    },
    "outputPath": {
      "type": "string",
      "minLength": 1
    },
    "requiredSections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
