{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jayson-furr.github.io/verityfoundry/schemas/generated-workspace-validation-result.schema.json",
  "title": "Generated Workspace Validation Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "workspaceId",
    "workspacePath",
    "sourceManifest",
    "generatedAt",
    "status",
    "tool",
    "checks",
    "fileHashes",
    "humanReviewRequired",
    "authorityBoundary",
    "unresolvedDecisions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "workspacePath": {
      "type": "string",
      "minLength": 1
    },
    "sourceManifest": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "skipped"
      ]
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "invocation"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "invocation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "command",
          "status",
          "exitCode",
          "outputSummary"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "skipped"
            ]
          },
          "exitCode": {
            "type": "integer",
            "minimum": 0
          },
          "outputSummary": {
            "type": "string"
          }
        }
      }
    },
    "fileHashes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "humanReviewRequired": {
      "type": "boolean",
      "const": true
    },
    "authorityBoundary": {
      "type": "string",
      "minLength": 1
    },
    "unresolvedDecisions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reviewerNotes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
