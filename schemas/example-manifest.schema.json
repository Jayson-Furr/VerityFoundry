{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jayson-Furr/VerityFoundry/schemas/example-manifest.schema.json",
  "title": "VerityFoundry example manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "domain",
    "interviewMode",
    "targetReadiness",
    "inputs",
    "expectedOutputs",
    "promptRefs",
    "notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "domain": {
      "type": "string"
    },
    "interviewMode": {
      "type": "string"
    },
    "targetReadiness": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "expectedOutputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "promptRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9.-]*\\.v[0-9]+$"
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
